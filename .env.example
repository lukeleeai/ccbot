# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "ccbot")
TMUX_SESSION_NAME=ccbot

# Agent backend to run in new windows: "claude" or "codex" (optional, defaults to "claude")
CCBOT_AGENT_BACKEND=claude

# Claude command when using the Claude backend (optional, defaults to "claude")
CLAUDE_COMMAND=claude

# Codex command when using the Codex backend (optional, defaults to "codex")
CODEX_COMMAND=codex

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0
